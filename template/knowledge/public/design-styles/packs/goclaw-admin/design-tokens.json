{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Goclaw Admin — canonical design tokens in DTCG format. Mirrors design-tokens.css. Dark-first industrial admin shell, monochrome zinc foundation, status-only accent color.",
  "$meta": {
    "id": "goclaw-admin",
    "version": "1.0.0",
    "updated": "2026-04-17",
    "status": "canonical",
    "source": "Extracted from an internal admin console reference @ commit 3bb35c5",
    "aesthetic": "Dark industrial admin console — monochrome zinc surfaces, Barlow Condensed uppercase display, hairline white/[0.06] rules, status-only color, fixed-rail sidebar shell for data-dense operations."
  },

  "font": {
    "sans":    { "$value": "Inter, ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily", "$description": "Body UI copy" },
    "display": { "$value": "Barlow Condensed, ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily", "$description": "Uppercase wordmarks, section labels, data headlines" },
    "mono":    { "$value": "IBM Plex Mono, ui-monospace, SFMono-Regular, Menlo, monospace", "$type": "fontFamily", "$description": "Numerals, IDs, timestamps, code strings" }
  },

  "tracking": {
    "body":    { "$value": "0.01em", "$type": "dimension", "$description": "Base body copy" },
    "label":   { "$value": "0.15em", "$type": "dimension", "$description": "Brand wordmark and bottom-rail metadata" },
    "section": { "$value": "0.2em",  "$type": "dimension", "$description": "9px uppercase section headings" }
  },

  "fontSize": {
    "9":    { "$value": "9px",  "$type": "dimension", "$description": "Uppercase display section heading" },
    "10":   { "$value": "10px", "$type": "dimension", "$description": "Micro mono labels" },
    "12":   { "$value": "12px", "$type": "dimension", "$description": "Nav items, dense table cells" },
    "xs":   { "$value": "12px", "$type": "dimension" },
    "sm":   { "$value": "14px", "$type": "dimension" },
    "base": { "$value": "16px", "$type": "dimension" },
    "lg":   { "$value": "18px", "$type": "dimension" },
    "xl":   { "$value": "20px", "$type": "dimension" },
    "2xl":  { "$value": "24px", "$type": "dimension" },
    "3xl":  { "$value": "30px", "$type": "dimension" }
  },

  "fontWeight": {
    "$description": "Four-stop weight system. Display weights are Barlow Condensed; body weights are Inter.",
    "inter-light":     { "$value": 300, "$type": "fontWeight" },
    "inter-regular":   { "$value": 400, "$type": "fontWeight" },
    "inter-medium":    { "$value": 500, "$type": "fontWeight" },
    "inter-semibold":  { "$value": 600, "$type": "fontWeight" },
    "display-regular": { "$value": 400, "$type": "fontWeight" },
    "display-medium":  { "$value": 500, "$type": "fontWeight" },
    "display-semibold":{ "$value": 600, "$type": "fontWeight" },
    "display-bold":    { "$value": 700, "$type": "fontWeight" },
    "mono-regular":    { "$value": 400, "$type": "fontWeight" },
    "mono-medium":     { "$value": 500, "$type": "fontWeight" }
  },

  "color": {
    "$description": "Monochrome zinc foundation, status-only accents. Dark-first — canonical page surface is zinc.950.",
    "zinc": {
      "50":  { "$value": "#fafafa", "$type": "color" },
      "100": { "$value": "#f4f4f5", "$type": "color" },
      "200": { "$value": "#e4e4e7", "$type": "color" },
      "300": { "$value": "#d4d4d8", "$type": "color" },
      "400": { "$value": "#a1a1aa", "$type": "color" },
      "500": { "$value": "#71717a", "$type": "color" },
      "600": { "$value": "#52525b", "$type": "color" },
      "700": { "$value": "#3f3f46", "$type": "color" },
      "800": { "$value": "#27272a", "$type": "color" },
      "900": { "$value": "#18181b", "$type": "color" },
      "950": { "$value": "#09090b", "$type": "color" }
    },

    "rail": {
      "bg": { "$value": "#0a0a0b", "$type": "color", "$description": "Sidebar rail — one tick warmer than zinc.950" }
    },

    "rule": {
      "$description": "Hairline border and fill alphas on dark surfaces.",
      "6":  { "$value": "rgba(255,255,255,0.06)", "$type": "color", "$description": "Structural rules + card borders" },
      "3":  { "$value": "rgba(255,255,255,0.03)", "$type": "color", "$description": "Hover fills on rows and nav items" },
      "8":  { "$value": "rgba(255,255,255,0.08)", "$type": "color", "$description": "Scrollbar thumb" },
      "15": { "$value": "rgba(255,255,255,0.15)", "$type": "color", "$description": "Scrollbar thumb hover" },
      "row": { "$value": "rgba(255,255,255,0.02)", "$type": "color", "$description": "Faint table row fill" }
    },

    "fg": {
      "strong":   { "$value": "#f4f4f5", "$type": "color" },
      "default":  { "$value": "#d4d4d8", "$type": "color" },
      "muted":    { "$value": "#a1a1aa", "$type": "color" },
      "dim":      { "$value": "#71717a", "$type": "color" },
      "dimmer":   { "$value": "#52525b", "$type": "color" },
      "dimmest":  { "$value": "#3f3f46", "$type": "color" }
    },

    "status": {
      "$description": "The only non-monochrome color on the surface. Reserved for live status.",
      "success": {
        "bg":  { "$value": "#022c22", "$type": "color", "$description": "emerald-950" },
        "fg":  { "$value": "#34d399", "$type": "color", "$description": "emerald-400" },
        "dot": { "$value": "#34d399", "$type": "color" }
      },
      "danger": {
        "bg":  { "$value": "#450a0a", "$type": "color", "$description": "red-950" },
        "fg":  { "$value": "#f87171", "$type": "color", "$description": "red-400" },
        "dot": { "$value": "#f87171", "$type": "color" }
      },
      "warning": {
        "bg":  { "$value": "#451a03", "$type": "color", "$description": "amber-950" },
        "fg":  { "$value": "#fbbf24", "$type": "color", "$description": "amber-400" },
        "dot": { "$value": "#fbbf24", "$type": "color" }
      },
      "info": {
        "bg":  { "$value": "#172554", "$type": "color", "$description": "blue-950 — in-flight operations" },
        "fg":  { "$value": "#60a5fa", "$type": "color", "$description": "blue-400" },
        "dot": { "$value": "#60a5fa", "$type": "color" }
      },
      "neutral": {
        "bg":  { "$value": "rgba(255,255,255,0.02)", "$type": "color" },
        "fg":  { "$value": "#a1a1aa", "$type": "color" },
        "dot": { "$value": "#a1a1aa", "$type": "color" }
      }
    }
  },

  "radius": {
    "$description": "Flat-first. Corners stay sharp on all data surfaces; small radii only for inputs and modals.",
    "0":  { "$value": "0px", "$type": "dimension" },
    "sm": { "$value": "2px", "$type": "dimension" },
    "md": { "$value": "4px", "$type": "dimension" }
  },

  "space": {
    "0":   { "$value": "0px",  "$type": "dimension" },
    "1":   { "$value": "4px",  "$type": "dimension" },
    "1-5": { "$value": "6px",  "$type": "dimension" },
    "2":   { "$value": "8px",  "$type": "dimension" },
    "2-5": { "$value": "10px", "$type": "dimension" },
    "3":   { "$value": "12px", "$type": "dimension" },
    "4":   { "$value": "16px", "$type": "dimension" },
    "5":   { "$value": "20px", "$type": "dimension" },
    "6":   { "$value": "24px", "$type": "dimension" },
    "8":   { "$value": "32px", "$type": "dimension" },
    "row-py": { "$value": "6px",  "$type": "dimension", "$description": "py-1.5 — dense table rows" },
    "cell-px":{ "$value": "10px", "$type": "dimension", "$description": "px-2.5 — status badge + cell inset" }
  },

  "shell": {
    "sidebar-width":         { "$value": "240px", "$type": "dimension", "$description": "Primary fixed rail" },
    "sidebar-width-compact": { "$value": "192px", "$type": "dimension", "$description": "Secondary — ultra-dense admins" },
    "topbar-height":         { "$value": "56px",  "$type": "dimension" }
  },

  "scrollbar": {
    "size":        { "$value": "4px", "$type": "dimension" },
    "thumb":       { "$value": "rgba(255,255,255,0.08)", "$type": "color" },
    "thumb-hover": { "$value": "rgba(255,255,255,0.15)", "$type": "color" }
  }
}

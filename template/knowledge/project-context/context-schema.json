{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hq.local/schemas/project-context.json",
  "title": "Project Context Manifest",
  "description": "Schema for validating project context structure",
  "type": "object",
  "required": ["project", "files"],
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name (must match projects/{name}/ directory)"
    },
    "files": {
      "type": "object",
      "description": "Context files included in this project",
      "required": ["overview", "architecture", "domain"],
      "properties": {
        "overview": {
          "type": "string",
          "description": "Path to overview.md (required)",
          "pattern": "^context/overview\\.md$"
        },
        "architecture": {
          "type": "string",
          "description": "Path to architecture.md (required)",
          "pattern": "^context/architecture\\.md$"
        },
        "domain": {
          "type": "string",
          "description": "Path to domain.md (required)",
          "pattern": "^context/domain\\.md$"
        },
        "decisions": {
          "type": "string",
          "description": "Path to decisions.md (recommended)",
          "pattern": "^context/decisions\\.md$"
        },
        "stakeholders": {
          "type": "string",
          "description": "Path to stakeholders.md (recommended)",
          "pattern": "^context/stakeholders\\.md$"
        },
        "learnings": {
          "type": "string",
          "description": "Path to learnings.md (optional)",
          "pattern": "^context/learnings\\.md$"
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata about the context",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When context was first created"
        },
        "last_audit": {
          "type": "string",
          "format": "date-time",
          "description": "When context was last audited for freshness"
        },
        "target_repo": {
          "type": "string",
          "description": "Path to the target repository this context describes"
        }
      }
    }
  },
  "additionalProperties": false
}

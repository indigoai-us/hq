{
  "outputStyle": "Explanatory",
  "autoMemoryEnabled": false,
  "model": "claude-opus-4-7",
  "env": {
    "MAX_THINKING_TOKENS": "31999",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh block-hq-glob .claude/hooks/block-hq-glob.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh block-hq-grep .claude/hooks/block-hq-grep.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh warn-cross-company-settings .claude/hooks/warn-cross-company-settings.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh detect-secrets .claude/hooks/detect-secrets.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh block-on-active-run .claude/hooks/block-on-active-run.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh protect-core .claude/hooks/protect-core.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh block-inline-story-impl .claude/hooks/block-inline-story-impl.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh block-on-active-run .claude/hooks/block-on-active-run.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh protect-core .claude/hooks/protect-core.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh block-inline-story-impl .claude/hooks/block-inline-story-impl.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh block-on-active-run .claude/hooks/block-on-active-run.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh auto-checkpoint-trigger .claude/hooks/auto-checkpoint-trigger.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh screenshot-resize-trigger .claude/hooks/screenshot-resize-trigger.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh auto-capture-registry .claude/hooks/auto-capture-registry.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh auto-checkpoint-trigger .claude/hooks/auto-checkpoint-trigger.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh auto-checkpoint-trigger .claude/hooks/auto-checkpoint-trigger.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh auto-checkpoint-precompact .claude/hooks/auto-checkpoint-precompact.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh observe-patterns .claude/hooks/observe-patterns.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh cleanup-mcp-processes .claude/hooks/cleanup-mcp-processes.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh context-warning-60 .claude/hooks/context-warning-60.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh load-policies .claude/hooks/load-policies-for-session.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh check-repo-active-runs .claude/hooks/check-repo-active-runs.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh inject-local-context $CLAUDE_PROJECT_DIR/.claude/hooks/inject-local-context.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh check-claude-desktop-bridge-health .claude/hooks/check-claude-desktop-bridge-health.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-gate.sh rewrite-resume-sentinel .claude/hooks/rewrite-resume-sentinel.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

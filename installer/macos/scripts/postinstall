#!/bin/bash
# =============================================================================
# my-hq macOS Installer - Post-install Script
# Minimal version for CI compatibility
# =============================================================================

exec >> /tmp/my-hq-installer.log 2>&1

echo "$(date): Starting postinstall"

# Get target user - simple fallback approach
TARGET_USER="${USER:-runner}"
if [ "$TARGET_USER" = "root" ]; then
    TARGET_USER=$(stat -f "%Su" /dev/console 2>/dev/null || echo "runner")
fi

# Get home directory
if [ -n "$TARGET_USER" ] && [ "$TARGET_USER" != "root" ]; then
    TARGET_HOME=$(eval echo "~$TARGET_USER" 2>/dev/null)
fi
TARGET_HOME="${TARGET_HOME:-/Users/runner}"

echo "$(date): Target user: $TARGET_USER"
echo "$(date): Target home: $TARGET_HOME"

# Source install location
SOURCE_DIR="/usr/local/my-hq"
DEST_DIR="$TARGET_HOME/my-hq"

echo "$(date): Source: $SOURCE_DIR"
echo "$(date): Dest: $DEST_DIR"

# Check if source exists
if [ ! -d "$SOURCE_DIR" ]; then
    echo "$(date): ERROR - Source directory not found: $SOURCE_DIR"
    # Still exit 0 to not fail the installer
    exit 0
fi

# Create destination
mkdir -p "$DEST_DIR" 2>/dev/null || true

# Copy files
if [ -d "$SOURCE_DIR" ]; then
    echo "$(date): Copying files..."
    cp -R "$SOURCE_DIR/"* "$DEST_DIR/" 2>/dev/null || true

    # Fix ownership if we can
    if [ -n "$TARGET_USER" ]; then
        chown -R "$TARGET_USER" "$DEST_DIR" 2>/dev/null || true
    fi

    echo "$(date): Files copied"
fi

# Create version file
echo "1.0.0" > "$DEST_DIR/.hq-version" 2>/dev/null || true

# List what was installed
echo "$(date): Installed files:"
ls -la "$DEST_DIR" 2>/dev/null || true

echo "$(date): Postinstall complete"
exit 0

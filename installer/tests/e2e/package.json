{
  "name": "hq-installer-e2e",
  "version": "1.0.0",
  "description": "E2E tests for HQ Installer landing page",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:browserbase": "USE_BROWSERBASE=true playwright test",
    "test:local": "USE_BROWSERBASE=false playwright test",
    "test:agent": "playwright test && node scripts/process-results.js",
    "report": "playwright show-report",
    "process-results": "node scripts/process-results.js"
  },
  "devDependencies": {
    "@browserbasehq/sdk": "^2.6.0",
    "@playwright/test": "^1.51.0",
    "playwright-core": "^1.51.0"
  }
}

{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/consult-knowledge.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-reindex.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/capture-learnings.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Claude just finished responding. If this was a substantive session (code changes, research, debugging), remind Claude to run /learn before the session ends. If it was a trivial exchange (greeting, short Q&A), return nothing. Return a short nudge or empty string.",
            "model": "claude-opus-4-6",
            "timeout": 60
          }
        ]
      }
    ]
  }
}

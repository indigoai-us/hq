{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "ask": [
      "Bash(cd ..*)",
      "Bash(cd /*)",
      "Bash(cd ~/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-checkpoint-trigger.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-handoff-trigger.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

{
  "permissions": {
    // "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(aws *)",
      "Bash(qmd *)",
      "Bash(bd *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(agent-browser *)",
      "Bash(ffmpeg *)",
      "Bash(ffprobe *)",
      "Bash(demucs *)",
      "Bash(whisper *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(brew *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tr *)",
      "Bash(date *)",
      "Bash(test *)",
      "Bash(which *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(readlink *)",
      "Bash(lsof *)",
      "Bash(source *)",
      "Bash(md5 *)",
      "Bash(claude *)"
    ],
    "ask": [
      "Bash(cd ..*)",
      "Bash(cd /*)",
      "Bash(cd ~/*)",
      "Bash(rm *)",
      "Bash(bd init --force)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-checkpoint-trigger.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-handoff-trigger.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
